# 基本语法
# 变量名称 = [元素1,元素2,.......]
# 定义空列表
# 变量名称 = []
# 变量名称 = list()
# 定义一个列表
name_list = ['itheima','itcast','ptthon']
print(name_list)
print(type(name_list))
print()
# 定义一个嵌套列表
name_list2 = [[1,2,3],[4,5,6]]
print(name_list2)
print(type(name_list2))
# 通过下标索引取出数据
print(name_list[0])
print(name_list[1])
print(name_list[2])
# 通过下标索引取出嵌套列表数据
print(name_list2[0][0])
print(name_list2[0][1])
print(name_list2[0][2])
print(name_list2[1][0])
print(name_list2[1][1])
print(name_list2[1][2])